{
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm tauribuild",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5174"
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "src-python/*"
    ],
    "targets": ["deb", "rpm", "appimage", "nsis", "app", "dmg"],
    "createUpdaterArtifacts": true,
    "fileAssociations": [
      {
        "ext": [
          "risum", "risup", "charx"
        ]
      }
    ]
  },
  "productName": "RisuGem",
  "mainBinaryName": "RisuGem",
  "version": "2026.4.240",
  "identifier": "com.bk927.risugem",
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRGRjU2RjQ3ODBGMUZDRUUKUldUdS9QR0FSMi8xVDZ5QzFmWE9seWp5TW5Zb1Mvc1BUSTNQN2JjamZXcTVlaURIMjFJYjI4NVkK",
      "endpoints": [
        "https://github.com/BK927/RisuGem/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    },
    "deep-link": {
      "desktop": {
        "schemes": ["risugemlocal"]
      }
    }
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "RisuGem",
        "width": 1024,
        "height": 768,
        "minWidth": 300,
        "minHeight": 500,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "assetProtocol": {
        "scope": [
          "asset",
          "$APPDATA",
          "$APPDATA/*",
          "$APPDATA/**/*",
          "/data/**/*"
        ],
        "enable": true
      },
      "csp": null
    }
  }
}